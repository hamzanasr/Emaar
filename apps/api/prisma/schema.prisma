// ============================================================
// Emaar Platform — Prisma Schema
// PostgreSQL database with full entity definitions
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  CLIENT
  CONTRACTOR
  SUPPLIER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  BIDDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum EscrowStatus {
  CREATED
  FUNDED
  HELD
  RELEASED
  PARTIALLY_RELEASED
  DISPUTED
  REFUNDED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum QualityVerdict {
  PASS
  FAIL
  CONDITIONAL_PASS
}

enum ChatRoomType {
  PROJECT
  ORDER
  SUPPORT
  DISPUTE
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
  VOICE
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  role          UserRole
  fullNameAr    String    @map("full_name_ar") @db.VarChar(100)
  fullNameEn    String    @map("full_name_en") @db.VarChar(100)
  phone         String    @unique @db.VarChar(20)
  email         String?   @db.VarChar(255)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  avatarUrl     String?   @map("avatar_url")
  kycStatus     KycStatus @default(PENDING) @map("kyc_status")
  kycDocuments  Json?     @map("kyc_documents")
  isActive      Boolean   @default(true) @map("is_active")
  regionId      String?   @map("region_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  region             Region?            @relation(fields: [regionId], references: [id])
  contractorProfile  ContractorProfile?
  supplierStore      SupplierStore?
  clientProjects     Project[]          @relation("ClientProjects")
  contractorProjects Project[]          @relation("ContractorProjects")
  bids               Bid[]
  buyerOrders        Order[]            @relation("BuyerOrders")
  sentMessages       ChatMessage[]      @relation("SentMessages")
  reviewsGiven       Review[]           @relation("ReviewsGiven")
  reviewsReceived    Review[]           @relation("ReviewsReceived")
  disputesRaised     Dispute[]          @relation("DisputesRaised")
  disputesAgainst    Dispute[]          @relation("DisputesAgainst")
  disputesResolved   Dispute[]          @relation("DisputesResolved")
  inspections        QualityInspection[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@index([role])
  @@index([phone])
  @@index([kycStatus])
  @@index([regionId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Region {
  id          String  @id @default(uuid()) @db.Uuid
  nameAr      String  @map("name_ar") @db.VarChar(100)
  nameEn      String  @map("name_en") @db.VarChar(100)
  countryCode String  @map("country_code") @db.VarChar(3)
  city        String  @db.VarChar(100)
  isActive    Boolean @default(true) @map("is_active")
  config      Json    @default("{}") // currency, taxRate, timezone

  users    User[]
  projects Project[]

  @@map("regions")
}

model Category {
  id        String  @id @default(uuid()) @db.Uuid
  nameAr    String  @map("name_ar") @db.VarChar(200)
  nameEn    String  @map("name_en") @db.VarChar(200)
  parentId  String? @map("parent_id") @db.Uuid
  icon      String? @db.VarChar(50)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  projects       Project[]
  supplierStores SupplierStore[]
  products       Product[]

  @@map("categories")
}

model ContractorProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  companyNameAr   String   @map("company_name_ar") @db.VarChar(200)
  companyNameEn   String   @map("company_name_en") @db.VarChar(200)
  licenseNumber   String   @map("license_number") @db.VarChar(50)
  specializations Json     @default("[]") // string[]
  qualityRating   Decimal  @default(0) @map("quality_rating") @db.Decimal(3, 2)
  totalProjects   Int      @default(0) @map("total_projects")
  portfolioUrls   Json     @default("[]") @map("portfolio_urls") // string[]
  bioAr           String?  @map("bio_ar")
  bioEn           String?  @map("bio_en")
  serviceRegions  String[] @map("service_regions") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contractor_profiles")
}

model SupplierStore {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @unique @map("user_id") @db.Uuid
  storeNameAr    String  @map("store_name_ar") @db.VarChar(200)
  storeNameEn    String  @map("store_name_en") @db.VarChar(200)
  categoryId     String  @map("category_id") @db.Uuid
  licenseNumber  String  @map("license_number") @db.VarChar(50)
  rating         Decimal @default(0) @db.Decimal(3, 2)
  deliveryZones  Json    @default("[]") @map("delivery_zones")
  commissionRate Decimal @default(3.00) @map("commission_rate") @db.Decimal(4, 2)
  isVerified     Boolean @default(false) @map("is_verified")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  products Product[]
  orders   Order[]

  @@index([categoryId])
  @@index([isVerified])
  @@map("supplier_stores")
}

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  clientId     String        @map("client_id") @db.Uuid
  contractorId String?       @map("contractor_id") @db.Uuid
  regionId     String        @map("region_id") @db.Uuid
  titleAr      String        @map("title_ar") @db.VarChar(300)
  titleEn      String        @map("title_en") @db.VarChar(300)
  description  String
  categoryId   String        @map("category_id") @db.Uuid
  totalBudget  Decimal       @map("total_budget") @db.Decimal(12, 2)
  currency     String        @default("SAR") @db.VarChar(3)
  status       ProjectStatus @default(DRAFT)
  address      Json?         // {lat, lng, formattedAddress, city, district}
  specs        Json?         // project specifications
  startDate    DateTime?     @map("start_date") @db.Date
  expectedEnd  DateTime?     @map("expected_end") @db.Date
  actualEnd    DateTime?     @map("actual_end") @db.Date
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  client     User     @relation("ClientProjects", fields: [clientId], references: [id])
  contractor User?    @relation("ContractorProjects", fields: [contractorId], references: [id])
  region     Region   @relation(fields: [regionId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  milestones  Milestone[]
  bids        Bid[]
  orders      Order[]
  chatRooms   ChatRoom[]
  disputes    Dispute[]
  reviews     Review[]

  @@index([clientId])
  @@index([contractorId])
  @@index([status])
  @@index([regionId])
  @@index([categoryId])
  @@map("projects")
}

model Bid {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  contractorId String    @map("contractor_id") @db.Uuid
  amount       Decimal   @db.Decimal(12, 2)
  duration     Int       // estimated days
  proposal     String
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractor User    @relation(fields: [contractorId], references: [id])

  @@unique([projectId, contractorId])
  @@index([projectId])
  @@index([contractorId])
  @@map("bids")
}

model Milestone {
  id            String          @id @default(uuid()) @db.Uuid
  projectId     String          @map("project_id") @db.Uuid
  titleAr       String          @map("title_ar") @db.VarChar(300)
  titleEn       String          @map("title_en") @db.VarChar(300)
  description   String?
  sequenceOrder Int             @map("sequence_order")
  amount        Decimal         @db.Decimal(12, 2)
  status        MilestoneStatus @default(PENDING)
  dueDate       DateTime?       @map("due_date") @db.Date
  submittedAt   DateTime?       @map("submitted_at") @db.Timestamptz
  approvedAt    DateTime?       @map("approved_at") @db.Timestamptz
  proofMedia    Json            @default("[]") @map("proof_media") // ProofMedia[]
  checklist     Json            @default("[]") // ChecklistItem[]
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  escrow      EscrowTransaction?
  inspections QualityInspection[]
  disputes    Dispute[]

  @@index([projectId])
  @@index([status])
  @@map("milestones")
}

model EscrowTransaction {
  id             String       @id @default(uuid()) @db.Uuid
  milestoneId    String       @unique @map("milestone_id") @db.Uuid
  projectId      String       @map("project_id") @db.Uuid
  payerId        String       @map("payer_id") @db.Uuid
  payeeId        String       @map("payee_id") @db.Uuid
  totalAmount    Decimal      @map("total_amount") @db.Decimal(12, 2)
  heldAmount     Decimal      @map("held_amount") @db.Decimal(12, 2)
  releasedAmount Decimal      @default(0) @map("released_amount") @db.Decimal(12, 2)
  platformFee    Decimal      @map("platform_fee") @db.Decimal(12, 2)
  status         EscrowStatus @default(CREATED)
  paymentRef     String?      @map("payment_ref") @db.VarChar(100)
  fundedAt       DateTime?    @map("funded_at") @db.Timestamptz
  releasedAt     DateTime?    @map("released_at") @db.Timestamptz
  expiresAt      DateTime?    @map("expires_at") @db.Timestamptz
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  milestone Milestone @relation(fields: [milestoneId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([payerId])
  @@index([payeeId])
  @@map("escrow_transactions")
}

model QualityInspection {
  id              String         @id @default(uuid()) @db.Uuid
  milestoneId     String         @map("milestone_id") @db.Uuid
  inspectorId     String         @map("inspector_id") @db.Uuid
  checklistScores Json           @map("checklist_scores") // ChecklistScore[]
  totalScore      Decimal        @map("total_score") @db.Decimal(5, 2)
  verdict         QualityVerdict
  notes           String?
  photos          Json           @default("[]") // string[]
  inspectedAt     DateTime       @map("inspected_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz

  milestone Milestone @relation(fields: [milestoneId], references: [id])
  inspector User      @relation(fields: [inspectorId], references: [id])

  @@index([milestoneId])
  @@index([inspectorId])
  @@map("quality_inspections")
}

model Product {
  id            String  @id @default(uuid()) @db.Uuid
  storeId       String  @map("store_id") @db.Uuid
  nameAr        String  @map("name_ar") @db.VarChar(300)
  nameEn        String  @map("name_en") @db.VarChar(300)
  descriptionAr String? @map("description_ar")
  descriptionEn String? @map("description_en")
  categoryId    String  @map("category_id") @db.Uuid
  price         Decimal @db.Decimal(10, 2)
  currency      String  @default("SAR") @db.VarChar(3)
  stockQuantity Int     @map("stock_quantity")
  unit          String  @db.VarChar(50)
  images        Json    @default("[]") // string[]
  specs         Json?   // product specifications
  isActive      Boolean @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  store      SupplierStore @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category      @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([storeId])
  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  projectId       String?     @map("project_id") @db.Uuid
  buyerId         String      @map("buyer_id") @db.Uuid
  storeId         String      @map("store_id") @db.Uuid
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  status          OrderStatus @default(PENDING)
  deliveryAddress Json        @map("delivery_address")
  trackingInfo    Json?       @map("tracking_info")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deliveredAt     DateTime?   @map("delivered_at") @db.Timestamptz

  project Project?      @relation(fields: [projectId], references: [id])
  buyer   User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  store   SupplierStore @relation(fields: [storeId], references: [id])
  items   OrderItem[]

  @@index([buyerId])
  @@index([storeId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model ChatRoom {
  id            String       @id @default(uuid()) @db.Uuid
  projectId     String?      @map("project_id") @db.Uuid
  type          ChatRoomType
  participants  String[]     @db.Uuid
  lastMessageAt DateTime?    @map("last_message_at") @db.Timestamptz
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  project  Project?      @relation(fields: [projectId], references: [id])
  messages ChatMessage[]

  @@index([projectId])
  @@index([participants])
  @@map("chat_rooms")
}

model ChatMessage {
  id        String      @id @default(uuid()) @db.Uuid
  roomId    String      @map("room_id") @db.Uuid
  senderId  String      @map("sender_id") @db.Uuid
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?     @map("media_url")
  readBy    String[]    @map("read_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Dispute {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @map("project_id") @db.Uuid
  milestoneId String?       @map("milestone_id") @db.Uuid
  raisedBy    String        @map("raised_by") @db.Uuid
  againstId   String        @map("against_id") @db.Uuid
  reason      String
  evidence    Json          @default("[]") // DisputeEvidence[]
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?       @map("resolved_by") @db.Uuid
  resolvedAt  DateTime?     @map("resolved_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  project   Project    @relation(fields: [projectId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
  raiser    User       @relation("DisputesRaised", fields: [raisedBy], references: [id])
  against   User       @relation("DisputesAgainst", fields: [againstId], references: [id])
  resolver  User?      @relation("DisputesResolved", fields: [resolvedBy], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("disputes")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  revieweeId String   @map("reviewee_id") @db.Uuid
  rating     Decimal  @db.Decimal(2, 1)
  comment    String?
  aspects    Json     // {quality, timeliness, communication, value}
  isVisible  Boolean  @default(true) @map("is_visible")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  project  Project @relation(fields: [projectId], references: [id])
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([projectId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  body      String
  type      String   @db.VarChar(50)
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  changes    Json?    // {before, after}
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
