# ═══════════════════════════════════════════════════════
# Emaar Platform — API Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql://emaar:emaar_dev_2024@localhost:5432/emaar?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=5

# SMS Provider (twilio | unifonic)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# AWS S3
AWS_S3_REGION=me-south-1
AWS_S3_BUCKET=emaar-media-dev
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
PRESIGNED_URL_EXPIRES=3600
MAX_FILE_SIZE=52428800

# Platform Fees
CONTRACTOR_FEE_PERCENT=5
SUPPLIER_COMMISSION_PERCENT=3
QUALITY_RESERVE_PERCENT=2

# Escrow
AUTO_APPROVAL_HOURS=72
QUALITY_RESERVE_DAYS=30

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
