# ═══════════════════════════════════════════════════════
# Emaar Platform — Web Portal Environment Variables
# ═══════════════════════════════════════════════════════

NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=إعمار

# Toggle to "true" to use mock data instead of hitting the backend.
# Useful during frontend development before the API is running.
# When "false" or unset, hooks call the real backend via NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_MOCK_DATA=true
